# Beta/Staging Environment Variables

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=dansbart_beta

# Authentication (DiscourseConnect — BFF pattern)
DISCOURSE_SSO_SECRET=
DISCOURSE_SSO_URL=
DISCOURSE_SSO_RETURN_URL=
SERVER_SECURE=true
SESSION_COOKIE_DOMAIN=

# Redis (session storage + Celery broker)
REDIS_HOST=redis
REDIS_PORT=6379

# Spotify (optional)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
