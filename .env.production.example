# Production Environment Variables

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=dansbart

# Authentication (DiscourseConnect — BFF pattern, no tokens in browser)
DISCOURSE_SSO_SECRET=
DISCOURSE_SSO_URL=
DISCOURSE_SSO_RETURN_URL=
SERVER_SECURE=true

# Redis (session storage + Celery broker)
REDIS_HOST=redis
REDIS_PORT=6379

# Spotify (optional — for ingestion)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
