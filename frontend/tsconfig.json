{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./js/*"
      ]
    }
  },
  "include": [
    "js/**/*",
    "admin/**/*",
    "tests/**/*",
    "vite.config.*",
    "vitest.config.*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}