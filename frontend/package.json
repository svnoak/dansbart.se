{
  "name": "dansbart-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "format": "prettier --write \"**/*.{js,vue,json,css,html}\"",
    "api:generate": "orval",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "check:contracts": "npm run api:generate && npm run typecheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "oidc-client-ts": "^3.0.1",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/ui": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "orval": "^7.3.0",
    "postcss": "^8.4.35",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.8"
  }
}
