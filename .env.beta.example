# Beta Environment Variables

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_beta_password
POSTGRES_DB=dansbart_beta

# Backend API
DATABASE_URL=postgresql://postgres:your_secure_beta_password@db:5432/dansbart_beta
SECRET_KEY=your_beta_secret_key_here
ADMIN_PASSWORD=your_secure_admin_password_here

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Keys (you can use test/dev keys here)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Environment
ENVIRONMENT=beta
DEBUG=true
